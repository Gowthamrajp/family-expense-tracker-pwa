# Firebase configuration for the Family Expense Tracker PWA.
#
# Copy this file to `.env` (or `.env.local`) and fill in the values from your
# Firebase project settings: Firebase console > Project settings > Your apps >
# SDK setup and configuration.
#
# The real `.env` file MUST NOT be committed. It is excluded by `.gitignore`
# (Req 7.6); only this `.env.example` with placeholder values is tracked.

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
