rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // The caller's family is read from their routing document at
    // users/{uid}.familyId.
    function callerFamily() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId;
    }
    // Access to family-scoped data is gated on the caller being a member of the
    // family that owns the data (Req 9.1, 9.2, 9.3).
    function isMember(familyId) {
      return request.auth != null && callerFamily() == familyId;
    }

    // Routing doc: a user may read/write only their own routing document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Invite-code index: any authenticated user may look up a code they know
    // (get-by-id only — no listing), revealing only the target familyId.
    match /inviteCodes/{code} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create: if request.auth != null;   // written at family creation
      allow update, delete: if false;
    }

    // Family document: members may read; creation must include the creator.
    match /families/{familyId} {
      allow read: if isMember(familyId);
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.memberUids;
      // Membership/ownership updates authorize exactly three transitions:
      //  (a) Self-join: a caller not previously in memberUids adds themselves
      //      (invite-code join), leaving ownerUid and inviteCode unchanged.
      //  (b) Owner membership management: the family's owner updates membership
      //      (e.g. removing a member — Req 12.3, 12.4).
      //  (c) One-time ownerUid backfill: when no owner is recorded, the
      //      original creator (memberUids[0]) sets ownerUid to themselves
      //      (Req 12.2).
      allow update: if request.auth != null && (
                      // (a) self-join
                      (
                        !(request.auth.uid in resource.data.memberUids)
                        && request.auth.uid in request.resource.data.memberUids
                        && request.resource.data.inviteCode == resource.data.inviteCode
                        && request.resource.data.get('ownerUid', '') == resource.data.get('ownerUid', '')
                      )
                      // (b) owner manages membership
                      || request.auth.uid == resource.data.get('ownerUid', '')
                      // (c) one-time owner backfill by the original creator
                      || (
                        resource.data.get('ownerUid', '') == ''
                        && resource.data.memberUids.size() > 0
                        && resource.data.memberUids[0] == request.auth.uid
                        && request.resource.data.ownerUid == request.auth.uid
                      )
                    );
      allow delete: if false;

      // All family-scoped data: members of THIS family only (Req 9.1, 9.2, 9.3).
      match /expenses/{expenseId} {
        allow read: if isMember(familyId);
        allow create: if isMember(familyId)
                      && request.resource.data.recordedBy == request.auth.uid;
        // Any member may edit/delete any expense in their family, regardless of
        // who recorded it (Req 3.18, 3.19, 9.4). Cross-family/unauthenticated
        // callers are rejected by isMember (Req 9.5). The rule cannot cheaply
        // assert recordedBy/createdAt are unchanged on update, so that
        // preservation (Req 3.15) is enforced in the data layer, which writes
        // only the editable fields plus updatedBy/updatedAt.
        allow update, delete: if isMember(familyId);
      }
      match /categories/{categoryId} {
        allow read: if isMember(familyId);
        allow create: if isMember(familyId);
        // Members may delete a category in their family (Req 4.7, 9.4). The
        // in-use block (Req 4.9) cannot be expressed in rules (no cheap
        // cross-document existence check) and is enforced in the data layer.
        allow delete: if isMember(familyId);
        allow update: if false;                // editing a category is out of scope
      }
      match /subSources/{subSourceId} {
        allow read: if isMember(familyId);
        // No-full-card-number guarantee (Req 9.7, 5.6): reject any payload with
        // extra fields; only source, nickname, and an optional 4-digit last4
        // are allowed.
        allow create: if isMember(familyId)
                      && request.resource.data.keys().hasOnly(['source','nickname','last4'])
                      && request.resource.data.nickname is string
                      && (!('last4' in request.resource.data)
                          || request.resource.data.last4.matches('^[0-9]{4}$'));
        // Members may delete a sub-source in their family (Req 5.8, 9.4). The
        // in-use block (Req 5.10) is enforced in the data layer, same as
        // categories.
        allow delete: if isMember(familyId);
        allow update: if false;                // editing a sub-source is out of scope
      }
      // Member_Profile: any member may read every profile in their family so
      // the member list can show readable names (Req 2.6, 2.9); a member may
      // write ONLY their own profile document (Req 2.7, 2.8). Cross-family and
      // other-member writes are denied, preserving isolation.
      match /members/{uid} {
        allow read: if isMember(familyId);
        allow create, update: if isMember(familyId) && request.auth.uid == uid;
        allow delete: if false;
      }
      // Recurring-payment rules: family-scoped templates that the client
      // materializes into expenses on app open. Members of the family may
      // read and manage them; create requires the rule be attributed to the
      // caller. Cross-family/unauthenticated access is denied by isMember.
      match /recurringRules/{ruleId} {
        allow read: if isMember(familyId);
        allow create: if isMember(familyId)
                      && request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if isMember(familyId);
      }
    }

    // TRANSITIONAL (legacy MVP data): the MVP stored expenses in a single
    // top-level `expenses` collection. The one-time client-side migration
    // (runs when the first family is created) copies ALL of these legacy docs
    // into the family's subcollection — every pre-existing expense belongs to
    // the family regardless of who recorded it. We therefore allow any
    // authenticated user to READ the legacy collection; no new writes are
    // permitted here (all new expense writes go through
    // families/{familyId}/expenses). Remove this block once migration is
    // complete for all users.
    match /expenses/{expenseId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }
  }
}
